<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.prilogenie.Manager.Schedule.ScheduleManager" BorderPane.alignment="CENTER" styleClass="main-bg" stylesheets="@../../styles.css">
    <top>
        <StackPane styleClass="card-block">
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0"/>
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="15.0">
                <Label text="Расписание маршрутов" styleClass="text-header"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox spacing="10.0">
                    <Button onAction="#handleRefresh" text="🔄 Обновить список" styleClass="btn-blue, btn-lg"/>
                </HBox>
            </HBox>
        </StackPane>
    </top>
    <center>
        <VBox spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="10" right="20" bottom="20" left="20"/>
            </padding>
            <TableView fx:id="table" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="numCol" text="№"/>
                    <TableColumn fx:id="typeCol" text="Тип" />
                    <TableColumn fx:id="fromCol" text="Направление А"/>
                    <TableColumn fx:id="toCol" text="Направление Б" />
                    <TableColumn fx:id="actCol" text="Действия"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>
    </center>
</BorderPane>