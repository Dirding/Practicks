<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.prilogenie.Manager.Schedule.Dialogschedule" styleClass="main-bg" stylesheets="@../../styles.css">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20"/>
    </padding>
    <children>
        <TableView fx:id="table" VBox.vgrow="ALWAYS" editable="true" styleClass="table-view">
            <placeholder>
                <Label text="Нет транспортных средств на маршруте" styleClass="text-label"/>
            </placeholder>
            <columns>
                <TableColumn fx:id="tripCol" prefWidth="100" text="Транспорт"/>
                <TableColumn fx:id="timeACol1" prefWidth="70" text="А"/>
                <TableColumn fx:id="timeBCol1" prefWidth="70" text="Б"/>
                <TableColumn fx:id="timeACol2" prefWidth="70" text="А"/>
                <TableColumn fx:id="timeBCol2" prefWidth="70" text="Б"/>
                <TableColumn fx:id="timeACol3" prefWidth="70" text="А"/>
                <TableColumn fx:id="timeBCol3" prefWidth="70" text="Б"/>
                <TableColumn fx:id="timeACol4" prefWidth="70" text="А"/>
                <TableColumn fx:id="timeBCol4" prefWidth="70" text="Б"/>
                <TableColumn fx:id="timeACol5" prefWidth="70" text="А"/>
                <TableColumn fx:id="timeBCol5" prefWidth="70" text="Б"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
        <HBox spacing="15" alignment="CENTER">
            <Button text="Сохранить" onAction="#handleSave" prefWidth="120" prefHeight="35" styleClass="btn-green, btn-lg"/>
            <Button fx:id="cancelBtn" text="Отмена" onAction="#handleCancel" prefWidth="120" prefHeight="35" styleClass="btn-red, btn-lg"/>
        </HBox>
    </children>
</VBox>