<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.ColumnConstraints?>
<GridPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.prilogenie.Manager.Stop.Dialogstop" hgap="15" vgap="15" alignment="CENTER" styleClass="main-bg" stylesheets="@../../styles.css">
    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>
    <columnConstraints>
        <ColumnConstraints minWidth="150" prefWidth="150"/>
        <ColumnConstraints minWidth="250" prefWidth="350"/>
    </columnConstraints>
    <Label text="Название:" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="text-label"/>
    <TextField fx:id="nameFld" promptText="Центральная" GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="text-field"/>
    <Label text="Адрес:" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="text-label"/>
    <TextField fx:id="addrFld" promptText="ул. Ленина, 1" GridPane.rowIndex="1" GridPane.columnIndex="1" styleClass="text-field"/>
    <HBox spacing="20.0" alignment="CENTER" GridPane.rowIndex="2" GridPane.columnIndex="0" GridPane.columnSpan="2">
        <Button text="Сохранить" onAction="#handleSave" prefWidth="140" styleClass="btn-green, btn-lg"/>
        <Button text="Отмена" onAction="#handleCancel" prefWidth="140" styleClass="btn-red, btn-lg"/>
        <padding>
            <Insets top="20.0" bottom="0.0" left="0.0" right="0.0"/>
        </padding>
    </HBox>
</GridPane>