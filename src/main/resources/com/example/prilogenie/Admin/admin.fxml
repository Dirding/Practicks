<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane prefHeight="700.0" prefWidth="1400.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.prilogenie.Admin.Admin"
            styleClass="main-bg"
            stylesheets="@../styles.css">
    <top>
        <StackPane styleClass="card-block">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
            </padding>
            <VBox alignment="CENTER" spacing="10.0">
                <Label text="Панель администратора" styleClass="text-header"/>
            </VBox>
        </StackPane>
    </top>
    <center>
        <VBox spacing="20.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
            </padding>
            <StackPane styleClass="card-block">
                <padding>
                    <Insets bottom="15.0" left="15.0" right="15.0" top="15.0"/>
                </padding>
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <Label text="Фильтры:" styleClass="text-label"/>
                    <ComboBox fx:id="roleFilter" prefWidth="150.0" styleClass="combo-box"/>
                    <ComboBox fx:id="statusFilter" prefWidth="150.0" styleClass="combo-box"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <HBox spacing="10.0">
                        <Button onAction="#handleAddUser" text="+ Добавить пользователя" styleClass="btn-green, btn-lg"/>
                        <Button onAction="#handleStatistics" text="📊 Статистика" styleClass="btn-orange, btn-lg"/>
                        <Button onAction="#handleLoadUsers" text="🔄 Обновить список" styleClass="btn-blue, btn-lg"/>
                    </HBox>
                </HBox>
            </StackPane>
            <Label text="Список пользователей" styleClass="text-label"/>
            <TableView fx:id="table" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="emailCol" prefWidth="250.0" minWidth="200.0" text="Email"/>
                    <TableColumn fx:id="loginCol" prefWidth="120.0" minWidth="100.0" text="Логин"/>
                    <TableColumn fx:id="roleCol" prefWidth="120.0" minWidth="100.0" text="Роль"/>
                    <TableColumn fx:id="activeCol" prefWidth="100.0" minWidth="80.0" text="Активен"/>
                    <TableColumn fx:id="actCol" prefWidth="380.0" minWidth="300.0" text="Действия"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
            <HBox alignment="CENTER_RIGHT" spacing="10.0">
                <Button onAction="#handleLogout" text="Выход" styleClass="btn-red, btn-lg"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>