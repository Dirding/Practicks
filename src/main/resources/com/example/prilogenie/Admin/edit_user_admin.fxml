<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox alignment="CENTER" maxWidth="650.0" prefHeight="500" prefWidth="650.0" spacing="15.0"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.prilogenie.Admin.EditUserAdmin"
      styleClass="main-bg"
      stylesheets="@../styles.css">
    <padding>
        <Insets bottom="15" left="30" right="30" top="15"/>
    </padding>
    <Label text="Редактирование пользователя" styleClass="text-header"/>
    <GridPane hgap="15" vgap="12">
        <columnConstraints>
            <ColumnConstraints prefWidth="150"/>
            <ColumnConstraints prefWidth="450"/>
        </columnConstraints>
        <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="text-label"/>
        <TextField fx:id="emailFld" prefWidth="380" promptText="Введите email (до 35 символов)" styleClass="text-field" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <Label text="Логин:" GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="text-label"/>
        <TextField fx:id="loginFld" prefWidth="380" promptText="Введите логин (до 20 символов)" styleClass="text-field" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        <Label text="Роль:" GridPane.columnIndex="0" GridPane.rowIndex="3" styleClass="text-label"/>
        <ComboBox fx:id="roleCombo" prefWidth="380" styleClass="combo-box" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
        <Label text="Новый пароль:" GridPane.columnIndex="0" GridPane.rowIndex="4" styleClass="text-label"/>
        <PasswordField fx:id="passFld" prefWidth="380" promptText="Оставьте пустым, чтобы не менять пароль" styleClass="password-field" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
        <Label text="Активен:" GridPane.columnIndex="0" GridPane.rowIndex="5" styleClass="text-label"/>
        <CheckBox fx:id="activeChk" styleClass="check-box" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
    </GridPane>
    <HBox alignment="CENTER" spacing="15.0">
        <Button fx:id="saveBtn" onAction="#handleSave" prefWidth="120" text="Сохранить" styleClass="btn-green, btn-lg"/>
        <Button onAction="#handleCancel" prefWidth="120" text="Отмена" styleClass="btn-red, btn-lg"/>
    </HBox>
</VBox>