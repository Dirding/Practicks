<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane prefHeight="700.0" prefWidth="1000.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="com.example.prilogenie.User.Account" styleClass="main-bg" stylesheets="@../styles.css">
    <top>
        <StackPane styleClass="card-block">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
            </padding>
            <VBox alignment="CENTER" spacing="10.0">
                <Label text="Настройки аккаунта" styleClass="text-header"/>
            </VBox>
        </StackPane>
    </top>
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <VBox alignment="TOP_CENTER" spacing="25.0">
                <padding>
                    <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
                </padding>
                <StackPane styleClass="card-block" maxWidth="1300">
                    <padding>
                        <Insets top="25.0" right="40.0" bottom="25.0" left="40.0"/>
                    </padding>
                    <VBox spacing="15.0">
                        <Label text="📋 Личные данные" styleClass="text-label"/>
                        <GridPane hgap="15" vgap="12">
                            <columnConstraints>
                                <ColumnConstraints minWidth="120"/>
                                <ColumnConstraints minWidth="300"/>
                            </columnConstraints>
                            <Label text="Email:" GridPane.rowIndex="0" GridPane.columnIndex="0"
                                   styleClass="text-label"/>
                            <TextField fx:id="emailFld" promptText="Email" GridPane.rowIndex="0"
                                       GridPane.columnIndex="1" styleClass="text-field"/>
                            <Label text="Логин:" GridPane.rowIndex="1" GridPane.columnIndex="0"
                                   styleClass="text-label"/>
                            <TextField fx:id="loginFld" promptText="Логин" GridPane.rowIndex="1"
                                       GridPane.columnIndex="1" styleClass="text-field"/>
                        </GridPane>
                    </VBox>
                </StackPane>
                <StackPane styleClass="card-block" maxWidth="1300">
                    <padding>
                        <Insets top="25.0" right="40.0" bottom="25.0" left="40.0"/>
                    </padding>
                    <VBox spacing="15.0">
                        <Label text="⭐ Избранные маршруты" styleClass="text-label"/>
                        <TableView fx:id="favTable" prefHeight="200.0" styleClass="table-view">
                            <columns>
                                <TableColumn fx:id="numCol" text="№ Маршрута" minWidth="120"/>
                                <TableColumn fx:id="nameCol" text="Направление" minWidth="400"/>
                                <TableColumn fx:id="actCol" text="" minWidth="100" maxWidth="100"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>
                    </VBox>
                </StackPane>
                <StackPane styleClass="card-block" maxWidth="1300">
                    <padding>
                        <Insets top="25.0" right="40.0" bottom="25.0" left="40.0"/>
                    </padding>
                    <VBox spacing="15.0">
                        <Label text="⚙ Управление аккаунтом" styleClass="text-label"/>
                        <HBox spacing="20.0" alignment="CENTER_LEFT">
                            <Button onAction="#handleLogout" text="Выйти из аккаунта" styleClass="btn-red, btn-lg"/>
                        </HBox>
                    </VBox>
                </StackPane>
            </VBox>
        </ScrollPane>
    </center>
    <bottom>
        <StackPane style="-fx-background-color: #000000; -fx-padding: 10 20;">
            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button onAction="#handleBack" text="Назад" styleClass="btn-blue, btn-lg"/>
            </HBox>
        </StackPane>
    </bottom>
</BorderPane>