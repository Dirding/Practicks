<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.prilogenie.User.ScheduleDetail" styleClass="main-bg" stylesheets="@../styles.css">
    <top>
        <StackPane styleClass="card-block">
            <padding>
                <Insets bottom="15.0" left="20.0" right="20.0" top="15.0"/>
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="20">
                <Label fx:id="numLabel" text="Маршрут №" styleClass="text-header"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="favBtn" onAction="#handleAddFav" text="★ В избранное" styleClass="btn-orange, btn-lg"/>
            </HBox>
        </StackPane>
    </top>
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="scroll-pane">
            <VBox fx:id="container" spacing="30" alignment="TOP_CENTER">
                <padding>
                    <Insets top="30" right="50" bottom="30" left="50"/>
                </padding>
                <Label text="Информация о маршруте" alignment="CENTER" maxWidth="1300" styleClass="text-header"/>
                <StackPane styleClass="card-block" maxWidth="1300">
                    <padding>
                        <Insets top="25" right="40" bottom="25" left="40"/>
                    </padding>
                    <VBox alignment="CENTER" spacing="25">
                        <HBox alignment="CENTER" spacing="100" maxWidth="1100">
                            <HBox spacing="10" alignment="CENTER">
                                <Label text="Тип транспорта:"
                                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #00ff88;"
                                       alignment="CENTER_RIGHT"/>
                                <Label fx:id="typeLabel" minWidth="100"
                                       styleClass="value-label"/>
                            </HBox>
                            <HBox spacing="10" alignment="CENTER">
                                <Label text="Стоимость:"
                                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #00ff88;"
                                       alignment="CENTER_RIGHT" minWidth="80"/>
                                <Label fx:id="costLabel" minWidth="100"
                                       styleClass="value-label"/>
                            </HBox>
                        </HBox>
                    </VBox>
                </StackPane>
                <HBox spacing="40" alignment="CENTER" maxWidth="1300">
                    <StackPane styleClass="card-block" HBox.hgrow="ALWAYS">
                        <padding>
                            <Insets top="20" right="30" bottom="20" left="30"/>
                        </padding>
                        <VBox alignment="CENTER" spacing="10">
                            <Label text="Отправление от A:" styleClass="text-header" style="-fx-font-size: 16px;"
                                   alignment="CENTER"/>
                            <Label fx:id="stopALabel" wrapText="true" alignment="CENTER" styleClass="value-label"/>
                        </VBox>
                    </StackPane>
                    <StackPane styleClass="card-block" HBox.hgrow="ALWAYS">
                        <padding>
                            <Insets top="20" right="30" bottom="20" left="30"/>
                        </padding>
                        <VBox alignment="CENTER" spacing="10">
                            <Label text="Отправление от Б:" styleClass="text-header" style="-fx-font-size: 16px;"
                                   alignment="CENTER"/>
                            <Label fx:id="stopBLabel" wrapText="true" alignment="CENTER" styleClass="value-label"/>
                        </VBox>
                    </StackPane>
                </HBox>
                <Label text="Остановки на маршруте" alignment="CENTER" maxWidth="1300" styleClass="text-header"/>
                <HBox spacing="40" alignment="CENTER" maxWidth="1300">
                    <StackPane styleClass="card-block" HBox.hgrow="ALWAYS">
                        <padding>
                            <Insets top="20" right="20" bottom="20" left="20"/>
                        </padding>
                        <VBox alignment="CENTER" spacing="15" maxWidth="600">
                            <Label text="A → Б" styleClass="text-header" style="-fx-font-size: 16px;"
                                   alignment="CENTER"/>
                            <VBox fx:id="stopsABox" alignment="CENTER" spacing="8" maxWidth="550"/>
                        </VBox>
                    </StackPane>
                    <StackPane styleClass="card-block" HBox.hgrow="ALWAYS">
                        <padding>
                            <Insets top="20" right="20" bottom="20" left="20"/>
                        </padding>
                        <VBox alignment="CENTER" spacing="15" maxWidth="600">
                            <Label text="Б → A" styleClass="text-header" style="-fx-font-size: 16px;"
                                   alignment="CENTER"/>
                            <VBox fx:id="stopsBBox" alignment="CENTER" spacing="8" maxWidth="550"/>
                        </VBox>
                    </StackPane>
                </HBox>
                <Label text="Расписание движения" styleClass="text-header" alignment="CENTER"/>
                <StackPane styleClass="card-block" maxWidth="1300">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>
                    <VBox fx:id="scheduleBox" spacing="20" alignment="CENTER">

                        <TableView fx:id="table" prefHeight="350" maxWidth="1200" styleClass="table-view">
                            <columns>
                                <TableColumn fx:id="vehicleCol" prefWidth="120" text="№"/>
                                <TableColumn fx:id="timeACol1" prefWidth="90" text="А"/>
                                <TableColumn fx:id="timeBCol1" prefWidth="90" text="Б"/>
                                <TableColumn fx:id="timeACol2" prefWidth="90" text="А"/>
                                <TableColumn fx:id="timeBCol2" prefWidth="90" text="Б"/>
                                <TableColumn fx:id="timeACol3" prefWidth="90" text="А"/>
                                <TableColumn fx:id="timeBCol3" prefWidth="90" text="Б"/>
                                <TableColumn fx:id="timeACol4" prefWidth="90" text="А"/>
                                <TableColumn fx:id="timeBCol4" prefWidth="90" text="Б"/>
                                <TableColumn fx:id="timeACol5" prefWidth="90" text="А"/>
                                <TableColumn fx:id="timeBCol5" prefWidth="90" text="Б"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>
                    </VBox>
                </StackPane>
            </VBox>
        </ScrollPane>
    </center>
    <bottom>
        <StackPane style="-fx-background-color: #000000; -fx-padding: 10 20;">
            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button onAction="#handleClose" text="Назад" styleClass="btn-blue, btn-lg"/>
            </HBox>
        </StackPane>
    </bottom>
</BorderPane>